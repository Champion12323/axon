enum AuditStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum RiskLevel {
  LOW       // 0–20%  fake score  — safe to hire
  MEDIUM    // 21–45% fake score  — proceed with caution
  HIGH      // 46–70% fake score  — risky
  CRITICAL  // 71–100% fake score — likely bought followers
}

model InfluencerAudit {
  id              String      @id @default(cuid())
  influencerId    String
  influencer      User        @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  platform        String      // "instagram" | "youtube" | "twitter" | "all"
  status          AuditStatus @default(PENDING)
  triggeredBy     String?     // userId who triggered (admin or brand)

  // Overall score
  fakeScore       Float       @default(0)   // 0–100, higher = more fake
  riskLevel       RiskLevel   @default(LOW)
  authenticScore  Float       @default(100) // 100 - fakeScore

  // Per-platform results (JSON)
  platformResults Json?       // { instagram: {...}, youtube: {...}, twitter: {...} }

  // Signal breakdown (stored for transparency)
  signals         Json?       // array of { name, weight, score, detail }

  // Recommendations
  verdict         String?     // human-readable summary
  flags           String[]    // ["low_engagement", "suspicious_growth", ...]

  completedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([influencerId])
  @@index([riskLevel])
  @@index([fakeScore])
  @@map("influencer_audits")
}

